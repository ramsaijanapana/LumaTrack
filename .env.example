# Copy this file to .env. The server auto-loads .env at startup.
LUMATRACK_HOST=127.0.0.1
LUMATRACK_PORT=5000
LUMATRACK_SECRET_KEY=replace-me-with-a-long-random-secret
# Optional. Set this when the app is served behind a reverse proxy or a public domain.
LUMATRACK_PUBLIC_BASE_URL=
LUMATRACK_ALLOWED_HOSTS=
LUMATRACK_TRUST_PROXY=false
LUMATRACK_SESSION_COOKIE_SECURE=
LUMATRACK_MAX_CONTENT_LENGTH=1048576
LUMATRACK_MIN_PASSWORD_LENGTH=12

# For hosted deployments, prefer PostgreSQL over local SQLite.
# Example Cloud SQL socket form:
# DATABASE_URL=postgresql://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# Enable any provider you want to use. Leave unset to hide that login option.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple requires a Sign in with Apple Service ID.
# Option A: provide a pre-generated client secret JWT directly.
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Option B: let the server generate the Apple client secret JWT at startup.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_CLIENT_SECRET_TTL_DAYS=180
