{
  "manifest_version": 3,
  "name": "Watchnest Companion",
  "version": "0.1.0",
  "description": "Capture the current OTT page and send a watch observation into Watchnest.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "https://*.onrender.com/*"],
  "action": {
    "default_title": "Watchnest Companion",
    "default_popup": "popup.html"
  }
}
