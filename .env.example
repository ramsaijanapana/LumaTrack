LUMATRACK_HOST=127.0.0.1
LUMATRACK_PORT=5000
LUMATRACK_SECRET_KEY=replace-me-with-a-long-random-secret

# Enable any provider you want to use. Leave unset to hide that login option.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple requires a Sign in with Apple Service ID and a generated client secret JWT.
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
